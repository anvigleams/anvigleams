rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───────────────────────────────────────────────────

    // True if the request comes from a signed-in Firebase Auth user (admin app login).
    function isAdmin() {
      return request.auth != null;
    }

    function isValidPhone(phone) {
      return phone is string && phone.matches('^\\+91[6-9][0-9]{9}$');
    }

    function isValidBookingId(id) {
      return id is string && id.matches('^AG-[A-Z0-9]{6}$');
    }

    function isValidDate(date) {
      return date is string && date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$');
    }

    function isValidTime(time) {
      return time is string && time.matches('^([01][0-9]|2[0-3]):[0-5][0-9]$');
    }

    // ─── Appointments ────────────────────────────────────────────────────────

    match /appointments/{docId} {

      // ✅ Admin (logged-in Flutter app) can do everything.
      allow read, write: if isAdmin();

      // ✅ Public: create a new booking with valid data.
      allow create: if
        !isAdmin() &&
        request.resource.data.keys().hasAll([
          'appointmentId', 'customerId', 'name', 'phone',
          'treatment', 'date', 'time', 'status', 'notes',
          'createdAt', 'updatedAt'
        ]) &&
        isValidBookingId(request.resource.data.appointmentId) &&
        isValidPhone(request.resource.data.phone) &&
        isValidDate(request.resource.data.date) &&
        isValidTime(request.resource.data.time) &&
        request.resource.data.status == 'pending' &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.name.size() <= 100 &&
        request.resource.data.notes is string &&
        request.resource.data.notes.size() <= 500 &&
        request.resource.data.offlineEntry == false;

      // ✅ Public: read appointments (needed for phone/ID tracking and slot checking).
      allow read: if !isAdmin();

      // ✅ Public: cancel only their own PENDING appointment.
      //    Only 'status' and 'updatedAt' fields may change.
      allow update: if
        !isAdmin() &&
        resource.data.status == 'pending' &&
        request.resource.data.status == 'cancelled' &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']);

      // ❌ Public cannot delete.
      allow delete: if false;
    }

    // ─── Customers ───────────────────────────────────────────────────────────

    match /customers/{docId} {

      // ✅ Admin: full access.
      allow read, write: if isAdmin();

      // ✅ Public: read customers to check for existing phone during booking upsert.
      //    (The server action queries by phone to decide create vs. reuse.)
      allow read: if !isAdmin();

      // ✅ Public: create their own customer record during booking.
      allow create: if
        !isAdmin() &&
        request.resource.data.keys().hasAll(['name', 'phone', 'createdAt', 'totalVisits']) &&
        isValidPhone(request.resource.data.phone) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.totalVisits == 0;

      // ❌ Public cannot update or delete customer records.
      allow update, delete: if false;
    }

    // ─── Payments ────────────────────────────────────────────────────────────

    match /payments/{docId} {

      // ✅ Admin: full access.
      allow read, write: if isAdmin();

      // ✅ Public: read payment info (shown on tracking page after completion).
      allow read: if !isAdmin();

      // ❌ Public cannot create, update, or delete payments.
      allow create, update, delete: if false;
    }

    // ─── Notifications ───────────────────────────────────────────────────────

    match /notifications/{docId} {
      // ✅ Admin only.
      allow read, write: if isAdmin();
    }

    // ─── Admin collection (if exists) ────────────────────────────────────────

    match /admins/{docId} {
      // ✅ Only an already-authenticated admin can read this.
      allow read: if isAdmin();
      allow write: if false; // Manage admins via Firebase Console only.
    }

    // ─── Catch-all: deny everything not explicitly covered ────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
