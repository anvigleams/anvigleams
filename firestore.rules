rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───────────────────────────────────────────────────

    // Only AnviGleams admin SDK (server) requests bypass security rules.
    // All rules below apply to client-side (web) Firebase SDK.

    function isValidPhone(phone) {
      return phone is string && phone.matches('^\\+91[6-9][0-9]{9}$');
    }

    function isValidStatus(status) {
      return status in ['pending', 'accepted', 'rejected', 'completed', 'missed', 'cancelled'];
    }

    function isValidBookingId(id) {
      return id is string && id.matches('^AG-[A-Z0-9]{6}$');
    }

    function isValidDate(date) {
      return date is string && date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$');
    }

    function isValidTime(time) {
      return time is string && time.matches('^([01][0-9]|2[0-3]):[0-5][0-9]$');
    }

    // ─── Appointments ────────────────────────────────────────────────────────

    match /appointments/{appointmentId} {
      // Anyone can CREATE (book) an appointment if the data is valid.
      allow create: if
        request.resource.data.keys().hasAll(['appointmentId', 'customerId', 'name', 'phone', 'treatment', 'date', 'time', 'status', 'notes', 'createdAt', 'updatedAt']) &&
        isValidBookingId(request.resource.data.appointmentId) &&
        isValidPhone(request.resource.data.phone) &&
        isValidDate(request.resource.data.date) &&
        isValidTime(request.resource.data.time) &&
        request.resource.data.status == 'pending' &&
        request.resource.data.name is string && request.resource.data.name.size() > 0 && request.resource.data.name.size() <= 100 &&
        request.resource.data.notes is string && request.resource.data.notes.size() <= 500 &&
        request.resource.data.offlineEntry == false; // Only admin SDK can set offlineEntry=true

      // Anyone can READ their own appointment by phone number (for tracking).
      // Clients can only query by their own phone (enforced at query level by server action).
      allow read: if true;

      // Only allow CLIENT to cancel their own PENDING appointment.
      // All other status changes (accept, reject, complete) must go through admin SDK.
      allow update: if
        resource.data.status == 'pending' &&
        request.resource.data.status == 'cancelled' &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']);

      // No client can delete appointments.
      allow delete: if false;
    }

    // ─── Customers ───────────────────────────────────────────────────────────

    match /customers/{customerId} {
      // Clients can create their own customer record during booking.
      allow create: if
        request.resource.data.keys().hasAll(['name', 'phone', 'createdAt', 'totalVisits']) &&
        isValidPhone(request.resource.data.phone) &&
        request.resource.data.name is string && request.resource.data.name.size() > 0 &&
        request.resource.data.totalVisits == 0;

      // No client can read, update, or delete customer records.
      // (Phone-based tracking reads appointments, not the customer document.)
      allow read, update, delete: if false;
    }

    // ─── Payments ────────────────────────────────────────────────────────────

    match /payments/{paymentId} {
      // Only admin SDK can create or modify payment records.
      // Clients can read their own payment summary (for the tracking page).
      allow read: if true;
      allow create, update, delete: if false;
    }

    // ─── Notifications ───────────────────────────────────────────────────────

    match /notifications/{notificationId} {
      allow read, write: if false;
    }

    // ─── Admin / Internal Collections ────────────────────────────────────────

    match /admins/{adminId} {
      allow read, write: if false;
    }

    // ─── Catch-All: Deny everything else ─────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
